          <mxGeometry x="200" y="60" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- API Gateway -->
        <mxCell id="apigw" value="API Gateway v2&#xa;HTTP API&#xa;Single HTTPS Entry Point&#xa;Cognito Authoriser" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.api_gateway;fillColor=#0D9488;strokeColor=#065f46;fontColor=#0F172A;fontSize=10;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier0">
          <mxGeometry x="400" y="60" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Cognito -->
        <mxCell id="cognito" value="Amazon Cognito&#xa;User Pools&#xa;JWT (RS256, 60 min)&#xa;Silent Refresh" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cognito;fillColor=#0D9488;strokeColor=#065f46;fontColor=#0F172A;fontSize=10;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier0">
          <mxGeometry x="600" y="60" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Tier 0 annotation -->
        <mxCell id="tier0-note" value="TLS 1.3 enforced on all inbound connections (COM-001, REQ-NF-008). WAF rejects TLS &lt; 1.3." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=9;fontColor=#64748B;fontStyle=2;" vertex="1" parent="tier0">
          <mxGeometry x="40" y="185" width="1060" height="20" as="geometry" />
        </mxCell>


        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- TIER 1 — BACKEND (LAMBDA)                                   -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="tier1" value="TIER 1 — BACKEND (AWS Lambda — Serverless, Auto-Scaling, VPC)" style="swimlane;startSize=30;fillColor=#eff6ff;strokeColor=#3b82f6;fontStyle=1;fontSize=12;fontColor=#1d4ed8;swimlaneLine=1;rounded=1;arcSize=3;" vertex="1" parent="1">
          <mxGeometry x="460" y="360" width="1140" height="280" as="geometry" />
        </mxCell>

        <!-- Lambda: auth-service -->
        <mxCell id="lam-auth" value="auth-service&#xa;Login / Logout&#xa;Token Refresh&#xa;Password Reset" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier1">
          <mxGeometry x="30" y="55" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Lambda: hospital-service -->
        <mxCell id="lam-hospital" value="hospital-service&#xa;Onboarding&#xa;Tenant Mgmt&#xa;Staff RBAC" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier1">
          <mxGeometry x="140" y="55" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Lambda: patient-service (provisioned concurrency) -->
        <mxCell id="lam-patient" value="patient-service ⚡&#xa;Registration&#xa;Search (pg_trgm)&#xa;Consent / Amend" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier1">
          <mxGeometry x="255" y="55" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Lambda: appointment-service -->
        <mxCell id="lam-appt" value="appointment-service&#xa;Schedule&#xa;Conflict Check&#xa;Calendar View" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier1">
          <mxGeometry x="370" y="55" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Lambda: clinical-service -->
        <mxCell id="lam-clinical" value="clinical-service&#xa;Encounters&#xa;Diagnoses / Vitals&#xa;Prescriptions" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier1">
          <mxGeometry x="485" y="55" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Lambda: lab-service -->
        <mxCell id="lam-lab" value="lab-service&#xa;Results Entry&#xa;Ref Range Check&#xa;Critical Alerts" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier1">
          <mxGeometry x="600" y="55" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Lambda: transfer-service -->
        <mxCell id="lam-transfer" value="transfer-service&#xa;Access Requests&#xa;Grant / Revoke&#xa;Expiry Alerts" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier1">
          <mxGeometry x="715" y="55" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Lambda: analytics-service (provisioned concurrency) -->
        <mxCell id="lam-analytics" value="analytics-service ⚡&#xa;Dashboard Queries&#xa;Materialized View&#xa;Refresh (5 min)" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier1">
          <mxGeometry x="830" y="55" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Lambda: notification-service -->
        <mxCell id="lam-notif" value="notification-service&#xa;In-App Polling&#xa;GET /notifications&#xa;(15s interval)" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier1">
          <mxGeometry x="945" y="55" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Lambda: bulk-ingestion -->
        <mxCell id="lam-etl" value="bulk-ingestion&#xa;CSV ETL&#xa;pg_trgm Dedup&#xa;S3 Trigger" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier1">
          <mxGeometry x="1060" y="55" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Tier 1 annotation -->
        <mxCell id="tier1-note" value="⚡ = Provisioned Concurrency (REQ-NF-005). All Lambda functions: VPC private subnet, JWT + permission check on every request (REQ-NF-011). Max concurrency capped at 200 (REQ-NF-021). Each function independently deployable (REQ-NF-023)." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=9;fontColor=#64748B;fontStyle=2;" vertex="1" parent="tier1">
          <mxGeometry x="30" y="210" width="1080" height="20" as="geometry" />
        </mxCell>

        <!-- Audit note -->
        <mxCell id="tier1-audit" value="Every Lambda reading/writing patient data writes to application_audit_log (REQ-F-068). audit_log table: INSERT + SELECT only — no UPDATE/DELETE (REQ-F-070)." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=9;fontColor=#64748B;fontStyle=2;" vertex="1" parent="tier1">
          <mxGeometry x="30" y="230" width="1080" height="20" as="geometry" />
        </mxCell>


        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- TIER 2 — DATA (VPC PRIVATE SUBNET)                          -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="tier2" value="TIER 2 — DATA (VPC Private Subnet — No Public IP)" style="swimlane;startSize=30;fillColor=#fef9c3;strokeColor=#ca8a04;fontStyle=1;fontSize=12;fontColor=#854d0e;swimlaneLine=1;rounded=1;arcSize=3;" vertex="1" parent="1">
          <mxGeometry x="460" y="670" width="1140" height="280" as="geometry" />
        </mxCell>

        <!-- RDS PostgreSQL -->
        <mxCell id="rds" value="Amazon RDS&#xa;PostgreSQL 15&#xa;&#xa;• AES-256 / KMS CMK&#xa;• VPC private subnet&#xa;• Daily snapshots 30d&#xa;• Point-in-time recovery&#xa;• pg_trgm GIN index&#xa;• Materialized views&#xa;• pg_cron scheduler&#xa;• application_audit_log&#xa;• notifications table&#xa;• 200 max connections" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.rds;fillColor=#ca8a04;strokeColor=#854d0e;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier2">
          <mxGeometry x="60" y="50" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- RDS label box -->
        <mxCell id="rds-box" value="PostgreSQL 15&#xa;• pg_trgm GIN index on (full_name, date_of_birth)&#xa;• Materialized views refreshed every 5 min (business hrs)&#xa;• application_audit_log — INSERT/SELECT only&#xa;• notifications table for polling&#xa;• Daily automated snapshots, 30-day retention&#xa;• Single-AZ MVP; Multi-AZ SHOULD for production" style="rounded=1;whiteSpace=wrap;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=9;fontColor=#0F172A;align=left;verticalAlign=top;" vertex="1" parent="tier2">
          <mxGeometry x="150" y="45" width="320" height="110" as="geometry" />
        </mxCell>

        <!-- S3 -->
        <mxCell id="s3" value="Amazon S3&#xa;&#xa;• CSV uploads (pre-signed URL)&#xa;• Static frontend assets&#xa;• CloudTrail logs&#xa;• Archive bucket (versioned)&#xa;• Lifecycle → Glacier 90d" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;fillColor=#ca8a04;strokeColor=#854d0e;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier2">
          <mxGeometry x="530" y="50" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- S3 label box -->
        <mxCell id="s3-box" value="S3 Buckets&#xa;• app-assets: Amplify static frontend&#xa;• csv-uploads: pre-signed URL ingestion&#xa;• cloudtrail-logs: versioned, write-protected, 2yr retention&#xa;• csv-archive: versioned, Glacier after 90 days" style="rounded=1;whiteSpace=wrap;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=9;fontColor=#0F172A;align=left;verticalAlign=top;" vertex="1" parent="tier2">
          <mxGeometry x="620" y="45" width="310" height="90" as="geometry" />
        </mxCell>

        <!-- KMS -->
        <mxCell id="kms" value="AWS KMS&#xa;CMK for RDS&#xa;CMK for S3&#xa;CMK for Secrets&#xa;Annual rotation" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.kms;fillColor=#ca8a04;strokeColor=#854d0e;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier2">
          <mxGeometry x="980" y="50" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Secrets Manager -->
        <mxCell id="secrets" value="Secrets Manager&#xa;DB credentials&#xa;API secrets&#xa;Runtime retrieval" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.secrets_manager;fillColor=#ca8a04;strokeColor=#854d0e;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier2">
          <mxGeometry x="1060" y="50" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Tier 2 annotation -->
        <mxCell id="tier2-note" value="All data encrypted at rest with AES-256 KMS CMKs (REQ-NF-007). No credentials in source code — runtime retrieval from Secrets Manager only (REQ-NF-009). Lambda connects to RDS via TCP within VPC private subnet (COM-004, REQ-NF-013)." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=9;fontColor=#64748B;fontStyle=2;" vertex="1" parent="tier2">
          <mxGeometry x="40" y="210" width="1080" height="20" as="geometry" />
        </mxCell>


        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- TIER 3 — NOTIFICATIONS                                      -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="tier3" value="TIER 3 — NOTIFICATIONS" style="swimlane;startSize=30;fillColor=#fff7ed;strokeColor=#ea580c;fontStyle=1;fontSize=12;fontColor=#c2410c;swimlaneLine=1;rounded=1;arcSize=3;" vertex="1" parent="1">
          <mxGeometry x="460" y="980" width="1140" height="210" as="geometry" />
        </mxCell>

        <!-- SES -->
        <mxCell id="ses" value="Amazon SES&#xa;Transactional Email&#xa;&#xa;• Critical lab alerts&#xa;• Transfer approvals&#xa;• ETL completion&#xa;• Daily summary 08:00 WAT&#xa;• Grant expiry 24h warning" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ses;fillColor=#ea580c;strokeColor=#c2410c;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier3">
          <mxGeometry x="120" y="50" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- SES details box -->
        <mxCell id="ses-box" value="SES Email Events&#xa;• Critical lab result → attending clinician + ward head nurse (within 60s) (REQ-F-066)&#xa;• Transfer request received → source hospital admin (REQ-F-051)&#xa;• Transfer grant expiry 24h warning → receiving hospital (REQ-F-054)&#xa;• ETL job completion report (REQ-F-047)&#xa;• Daily summary at 08:00 WAT / UTC+1 (REQ-F-067)" style="rounded=1;whiteSpace=wrap;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=9;fontColor=#0F172A;align=left;verticalAlign=top;" vertex="1" parent="tier3">
          <mxGeometry x="210" y="45" width="440" height="100" as="geometry" />
        </mxCell>

        <!-- SNS -->
        <mxCell id="sns" value="Amazon SNS&#xa;Internal Event Bus&#xa;Decouples Lambda&#xa;from SES delivery" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.sns;fillColor=#ea580c;strokeColor=#c2410c;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier3">
          <mxGeometry x="720" y="50" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- SNS details box -->
        <mxCell id="sns-box" value="SNS Topics&#xa;• critical-lab-alerts → SES subscription&#xa;• transfer-events → SES subscription&#xa;• system-alerts → CloudWatch alarm → admin email&#xa;Decouples event producers (Lambda) from email delivery (SES)" style="rounded=1;whiteSpace=wrap;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=9;fontColor=#0F172A;align=left;verticalAlign=top;" vertex="1" parent="tier3">
          <mxGeometry x="810" y="45" width="290" height="90" as="geometry" />
        </mxCell>

        <!-- Tier 3 annotation -->
        <mxCell id="tier3-note" value="In-app notifications: client polls GET /notifications every 15s. Records stored in RDS notifications table (REQ-F-064, REQ-F-065). Email via SES. SNS decouples Lambda from SES (Section 3.2.12)." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=9;fontColor=#64748B;fontStyle=2;" vertex="1" parent="tier3">
          <mxGeometry x="40" y="160" width="1060" height="20" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- TIER 4 — OBSERVABILITY                                      -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <mxCell id="tier4" value="TIER 4 — OBSERVABILITY &amp; AUDIT" style="swimlane;startSize=30;fillColor=#f5f3ff;strokeColor=#7c3aed;fontStyle=1;fontSize=12;fontColor=#5b21b6;swimlaneLine=1;rounded=1;arcSize=3;" vertex="1" parent="1">
          <mxGeometry x="460" y="1220" width="1140" height="210" as="geometry" />
        </mxCell>

        <!-- CloudTrail -->
        <mxCell id="cloudtrail" value="AWS CloudTrail&#xa;Infrastructure Audit&#xa;&#xa;• All AWS API calls&#xa;• 2-year retention&#xa;• Versioned S3 bucket&#xa;• Write-protected" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudtrail;fillColor=#7c3aed;strokeColor=#5b21b6;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier4">
          <mxGeometry x="120" y="50" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="cloudtrail-box" value="CloudTrail — Infrastructure Level (REQ-F-071)&#xa;Records all AWS API calls. Does NOT record clinical data access.&#xa;Stored in dedicated versioned write-protected S3 bucket.&#xa;Minimum 2-year retention." style="rounded=1;whiteSpace=wrap;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=9;fontColor=#0F172A;align=left;verticalAlign=top;" vertex="1" parent="tier4">
          <mxGeometry x="210" y="45" width="380" height="75" as="geometry" />
        </mxCell>

        <!-- CloudWatch -->
        <mxCell id="cloudwatch" value="Amazon CloudWatch&#xa;Monitoring &amp; Alarms&#xa;&#xa;• Structured JSON logs&#xa;• Lambda error rate &gt;5/min&#xa;• RDS CPU &gt;80% for 5 min&#xa;• Alarms → SNS → Admin" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch;fillColor=#7c3aed;strokeColor=#5b21b6;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier4">
          <mxGeometry x="650" y="50" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="cloudwatch-box" value="CloudWatch (REQ-NF-019, REQ-NF-024)&#xa;Structured JSON logs: function name, request ID, user ID, hospital ID, timestamp (WAT), level, message.&#xa;Alarms: Lambda error rate &gt;5/min OR RDS CPU &gt;80% for 5 min → SNS notify admin within 5 min." style="rounded=1;whiteSpace=wrap;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=9;fontColor=#0F172A;align=left;verticalAlign=top;" vertex="1" parent="tier4">
          <mxGeometry x="740" y="45" width="360" height="75" as="geometry" />
        </mxCell>

        <!-- Tier 4 annotation -->
        <mxCell id="tier4-note" value="Two-tier audit: CloudTrail = infrastructure (AWS API calls) | application_audit_log in RDS = clinical data access (REQ-F-068 to REQ-F-070). Both required for Cameroon Law No. 2010/012 compliance." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=9;fontColor=#64748B;fontStyle=2;" vertex="1" parent="tier4">
          <mxGeometry x="40" y="160" width="1060" height="20" as="geometry" />
        </mxCell>


        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- DATA FLOW ARROWS                                            -->
        <!-- ═══════════════════════════════════════════════════════════ -->

        <!-- Client → Amplify (HTTPS/TLS 1.3) -->
        <mxCell id="e-client-amplify" value="HTTPS / TLS 1.3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0D9488;strokeWidth=2;fontColor=#0D9488;fontSize=9;fontStyle=1;" edge="1" parent="1" source="browser" target="amplify">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Client → WAF → API Gateway -->
        <mxCell id="e-client-waf" value="API Requests&#xa;TLS 1.3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0D9488;strokeWidth=2;fontColor=#0D9488;fontSize=9;" edge="1" parent="1" source="browser" target="waf">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-waf-apigw" value="Filtered" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0D9488;strokeWidth=2;fontColor=#0D9488;fontSize=9;" edge="1" parent="1" source="waf" target="apigw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Client ↔ Cognito (Auth) -->
