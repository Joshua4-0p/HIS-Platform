        <mxCell id="title" value="HIS — Scalable Cloud-Based Healthcare Architecture (AWS af-south-1)&#xa;University of Buea | SRS v2.0 | 13-Service Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#0F172A;" vertex="1" parent="1">
