<mxfile host="app.diagrams.net" modified="2026-06-25" version="21.0.0">
  <diagram name="HIS AWS Architecture v2.1" id="his-aws-arch">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="2400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
