        <!-- TITLE -->
        <mxCell id="title" value="HIS — AWS Architecture (us-east-1) | SRS v2.0 | MVP Build" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1;fontColor=#0F172A;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="900" height="40" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════ -->
        <!-- TIER 0 — PRESENTATION      -->
        <!-- ═══════════════════════════ -->
        <mxCell id="tier0" value="TIER 0 — PRESENTATION" style="swimlane;startSize=30;fillColor=#f0fdf4;strokeColor=#0D9488;fontStyle=1;fontSize=11;fontColor=#0D9488;rounded=1;arcSize=3;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="900" height="290" as="geometry" />
        </mxCell>

        <mxCell id="amplify" value="Amplify&#xa;+ CloudFront" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.amplify;fillColor=#0D9488;strokeColor=#065f46;fontColor=#0F172A;fontSize=10;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier0">
          <mxGeometry x="100" y="65" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="apigw" value="API Gateway v2&#xa;HTTP API" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.api_gateway;fillColor=#0D9488;strokeColor=#065f46;fontColor=#0F172A;fontSize=10;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier0">
          <mxGeometry x="400" y="65" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="cognito" value="Cognito&#xa;User Pools" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cognito;fillColor=#0D9488;strokeColor=#065f46;fontColor=#0F172A;fontSize=10;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier0">
          <mxGeometry x="700" y="65" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="waf-deferred" value="⚠ AWS WAF — Production only (not deployed in MVP)&#xa;Compensating controls: API Gateway throttling + Cognito JWT authoriser" style="rounded=1;whiteSpace=wrap;fillColor=#fee2e2;strokeColor=#ef4444;fontSize=9;fontColor=#991b1b;align=center;" vertex="1" parent="tier0">
          <mxGeometry x="80" y="185" width="740" height="45" as="geometry" />
        </mxCell>

        <mxCell id="t0-note" value="TLS 1.3 enforced at API Gateway (COM-001). JWT RS256, 60-min expiry, silent refresh (COM-003). All API responses: REST + JSON (COM-002)." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=9;fontColor=#475569;fontStyle=2;" vertex="1" parent="tier0">
          <mxGeometry x="40" y="248" width="820" height="20" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════ -->
        <!-- VPC BOUNDARY                            -->
        <!-- ═══════════════════════════════════════ -->
        <mxCell id="vpc" value="AWS VPC — us-east-1" style="swimlane;startSize=28;fillColor=#f8fafc;strokeColor=#64748b;fontStyle=1;fontSize=11;fontColor=#334155;rounded=1;arcSize=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="390" width="900" height="1020" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════ -->
        <!-- PUBLIC SUBNET — LAMBDA                 -->
        <!-- ═══════════════════════════════════════ -->
        <mxCell id="pub-subnet" value="Private Isolated Subnets — Lambda Functions (9 VPC-bound | auth-service: No VPC attachment — Cognito access only)" style="swimlane;startSize=28;fillColor=#eff6ff;strokeColor=#3b82f6;fontStyle=1;fontSize=10;fontColor=#1d4ed8;rounded=1;arcSize=2;" vertex="1" parent="vpc">
          <mxGeometry x="20" y="40" width="860" height="560" as="geometry" />
        </mxCell>

        <!-- Row 1 of Lambda functions -->
        <mxCell id="lam-auth" value="auth-service&#xa;⚡ No VPC" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#f0fdf4;strokeColor=#059669;fontColor=#065f46;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="pub-subnet">
          <mxGeometry x="30" y="55" width="52" height="52" as="geometry" />
        </mxCell>
        <mxCell id="lam-hospital" value="hospital-service" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="pub-subnet">
          <mxGeometry x="180" y="55" width="52" height="52" as="geometry" />
        </mxCell>
        <mxCell id="lam-patient" value="patient-service" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="pub-subnet">
          <mxGeometry x="330" y="55" width="52" height="52" as="geometry" />
        </mxCell>
        <mxCell id="lam-appt" value="appointment-service" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="pub-subnet">
          <mxGeometry x="480" y="55" width="52" height="52" as="geometry" />
        </mxCell>
        <mxCell id="lam-clinical" value="clinical-service" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="pub-subnet">
          <mxGeometry x="630" y="55" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Lambda SG annotation row 1 -->
        <mxCell id="sg-ann1" value="Lambda SG (9 VPC-bound): outbound 443 → VPC CIDR only (SNS via VPC Interface Endpoint) | outbound 5432 → RDS SG only | no inbound | auth-service: no VPC — direct Cognito access" style="rounded=1;whiteSpace=wrap;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=9;fontColor=#1e3a5f;align=center;" vertex="1" parent="pub-subnet">
          <mxGeometry x="20" y="155" width="820" height="28" as="geometry" />
        </mxCell>

        <!-- Row 2 of Lambda functions -->
        <mxCell id="lam-lab" value="lab-service" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="pub-subnet">
          <mxGeometry x="30" y="210" width="52" height="52" as="geometry" />
        </mxCell>
        <mxCell id="lam-transfer" value="transfer-service" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="pub-subnet">
          <mxGeometry x="180" y="210" width="52" height="52" as="geometry" />
        </mxCell>
        <mxCell id="lam-analytics" value="analytics-service" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="pub-subnet">
          <mxGeometry x="330" y="210" width="52" height="52" as="geometry" />
        </mxCell>
        <mxCell id="lam-notif" value="notification-service" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="pub-subnet">
          <mxGeometry x="480" y="210" width="52" height="52" as="geometry" />
        </mxCell>
        <mxCell id="lam-etl" value="bulk-ingestion" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;fillColor=#3b82f6;strokeColor=#1d4ed8;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="pub-subnet">
          <mxGeometry x="630" y="210" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- Lambda SG annotation row 2 -->
        <mxCell id="sg-ann2" value="Lambda SG (9 VPC-bound): outbound 443 → VPC CIDR only (SNS via VPC Interface Endpoint) | outbound 5432 → RDS SG only | no inbound | auth-service: no VPC — direct Cognito access" style="rounded=1;whiteSpace=wrap;fillColor=#dbeafe;strokeColor=#3b82f6;fontSize=9;fontColor=#1e3a5f;align=center;" vertex="1" parent="pub-subnet">
          <mxGeometry x="20" y="308" width="820" height="28" as="geometry" />
        </mxCell>

        <!-- DLQ for bulk-ingestion -->
        <mxCell id="dlq" value="SQS DLQ&#xa;(bulk-ingestion)" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.sqs;fillColor=#e0f2fe;strokeColor=#0369a1;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="pub-subnet">
          <mxGeometry x="630" y="370" width="52" height="52" as="geometry" />
        </mxCell>

        <!-- S3 Gateway Endpoint -->
        <mxCell id="s3ep" value="S3 VPC Gateway Endpoint (free) — S3 traffic stays on AWS private network | SNS VPC Interface Endpoint (~$7.20/mo) — SNS access for lab-service, transfer-service, notification-service, bulk-ingestion | No NAT Gateway, no Secrets Manager endpoint (IAM DB auth), no Cognito-IDP endpoint (auth-service outside VPC)" style="rounded=1;whiteSpace=wrap;fillColor=#f0fdf4;strokeColor=#059669;fontSize=9;fontColor=#064e3b;align=center;" vertex="1" parent="pub-subnet">
          <mxGeometry x="20" y="450" width="820" height="28" as="geometry" />
        </mxCell>

        <mxCell id="pub-note" value="JWT + permission check on every request (REQ-NF-011). Concurrency cap: 200 (REQ-NF-021). Independent deployability (REQ-NF-023). All functions write to application_audit_log (REQ-F-068). RDS access via IAM DB auth — no stored DB password (REQ-NF-009)." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=9;fontColor=#475569;fontStyle=2;" vertex="1" parent="pub-subnet">
          <mxGeometry x="20" y="498" width="820" height="20" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════ -->
        <!-- PRIVATE SUBNET — DATA                  -->
        <!-- ═══════════════════════════════════════ -->
        <mxCell id="priv-subnet" value="Private Subnet — Data (No Public IP | RDS SG: inbound port 5432 from Lambda SG only)" style="swimlane;startSize=28;fillColor=#fef9c3;strokeColor=#ca8a04;fontStyle=1;fontSize=10;fontColor=#854d0e;rounded=1;arcSize=2;" vertex="1" parent="vpc">
          <mxGeometry x="20" y="630" width="860" height="360" as="geometry" />
        </mxCell>

        <!-- RDS -->
        <mxCell id="rds" value="RDS PostgreSQL 15&#xa;db.t3.micro" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.rds;fillColor=#ca8a04;strokeColor=#854d0e;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="priv-subnet">
          <mxGeometry x="80" y="55" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="rds-box" value="PostgreSQL 15 · db.t3.micro · Single-AZ · AWS managed encryption (AES-256) · iamAuthentication=true&#xa;pg_trgm GIN index · Materialized views · pg_cron (custom param group) · application_audit_log · notifications table&#xa;Backup: 2d MVP → 30d prod | PITR enabled | IAM DB auth: rds_iam role granted to his_app | Upgrade path: Aurora Serverless v2 (CDK Stack 2 swap)" style="rounded=1;whiteSpace=wrap;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=9;fontColor=#0F172A;align=left;verticalAlign=top;" vertex="1" parent="priv-subnet">
          <mxGeometry x="165" y="45" width="670" height="75" as="geometry" />
        </mxCell>

        <!-- Secrets Manager -->
        <mxCell id="secrets" value="Secrets Manager&#xa;DB + API secrets" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.secrets_manager;fillColor=#ca8a04;strokeColor=#854d0e;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="priv-subnet">
          <mxGeometry x="80" y="170" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="secrets-box" value="Deploy-time secret access only — no VPC-bound Lambda calls Secrets Manager at runtime (REQ-NF-009)&#xa;Stores: GitHub OAuth token (CDK deploy only) · SES SMTP credentials&#xa;RDS access: replaced by IAM database authentication — short-lived tokens, no stored DB password" style="rounded=1;whiteSpace=wrap;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=9;fontColor=#0F172A;align=left;verticalAlign=top;" vertex="1" parent="priv-subnet">
          <mxGeometry x="165" y="165" width="670" height="55" as="geometry" />
        </mxCell>

        <!-- KMS managed key note -->
        <mxCell id="kms-note" value="Encryption: AWS Managed Keys (aws/rds · aws/s3 · aws/secretsmanager) — AES-256 at rest applied to all data stores. KMS CMKs with annual rotation are a Production P1 enhancement (REQ-NF-007/014)." style="rounded=1;whiteSpace=wrap;fillColor=#fff7ed;strokeColor=#f59e0b;fontSize=9;fontColor=#78350f;align=left;verticalAlign=top;" vertex="1" parent="priv-subnet">
          <mxGeometry x="80" y="260" width="755" height="40" as="geometry" />
        </mxCell>

        <mxCell id="priv-note" value="No internet gateway route from this subnet. RDS not publicly accessible. Inbound to RDS: port 5432 from Lambda SG only." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=9;fontColor=#475569;fontStyle=2;" vertex="1" parent="priv-subnet">
          <mxGeometry x="20" y="320" width="820" height="20" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════ -->
        <!-- TIER 3 — S3 + SES          -->
        <!-- ═══════════════════════════ -->
        <mxCell id="tier3" value="TIER 3 — STORAGE &amp; NOTIFICATIONS" style="swimlane;startSize=30;fillColor=#fff7ed;strokeColor=#ea580c;fontStyle=1;fontSize=11;fontColor=#c2410c;rounded=1;arcSize=3;" vertex="1" parent="1">
          <mxGeometry x="30" y="1430" width="900" height="260" as="geometry" />
        </mxCell>

        <mxCell id="s3" value="Amazon S3" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;fillColor=#ea580c;strokeColor=#c2410c;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier3">
          <mxGeometry x="60" y="55" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="s3-box" value="S3 Buckets (accessed via VPC Gateway Endpoint — no NAT)&#xa;• csv-uploads: pre-signed URL ingestion → triggers bulk-ingestion Lambda (REQ-F-044)&#xa;• csv-archive: versioned · Glacier lifecycle after 90 days (REQ-F-048)&#xa;• cloudtrail-logs: versioned · write-protected · 2yr retention (REQ-F-071)" style="rounded=1;whiteSpace=wrap;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=9;fontColor=#0F172A;align=left;verticalAlign=top;" vertex="1" parent="tier3">
          <mxGeometry x="145" y="45" width="720" height="80" as="geometry" />
        </mxCell>

        <mxCell id="ses" value="Amazon SES&#xa;(Sandbox)" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.ses;fillColor=#ea580c;strokeColor=#c2410c;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier3">
          <mxGeometry x="60" y="165" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ses-box" value="SES Sandbox — verified addresses: josuefotseu02@gmail.com · joshuaer03@gmail.com · joshiboss04@gmail.com&#xa;Events: critical lab alert within 60s (REQ-F-066) · transfer events (REQ-F-051/054) · ETL completion (REQ-F-047) · daily summary 08:00 WAT (REQ-F-067)&#xa;Go-live requirement: SES production access + domain verification before real hospital use" style="rounded=1;whiteSpace=wrap;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=9;fontColor=#0F172A;align=left;verticalAlign=top;" vertex="1" parent="tier3">
          <mxGeometry x="145" y="155" width="720" height="70" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════ -->
        <!-- TIER 4 — OBSERVABILITY     -->
        <!-- ═══════════════════════════ -->
        <mxCell id="tier4" value="TIER 4 — OBSERVABILITY &amp; AUDIT" style="swimlane;startSize=30;fillColor=#f5f3ff;strokeColor=#7c3aed;fontStyle=1;fontSize=11;fontColor=#5b21b6;rounded=1;arcSize=3;" vertex="1" parent="1">
          <mxGeometry x="30" y="1710" width="900" height="280" as="geometry" />
        </mxCell>

        <mxCell id="sns" value="Amazon SNS&#xa;Event Bus" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.sns;fillColor=#7c3aed;strokeColor=#5b21b6;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier4">
          <mxGeometry x="60" y="55" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="sns-box" value="SNS Topics: critical-lab-alerts → SES subscription | transfer-events → SES subscription | system-alarms → admin email&#xa;Decouples Lambda event producers from SES delivery. No sandbox restrictions on SNS pub/sub." style="rounded=1;whiteSpace=wrap;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=9;fontColor=#0F172A;align=left;verticalAlign=top;" vertex="1" parent="tier4">
          <mxGeometry x="145" y="48" width="720" height="55" as="geometry" />
        </mxCell>

        <mxCell id="cloudwatch" value="CloudWatch&#xa;Logs &amp; Alarms" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch;fillColor=#7c3aed;strokeColor=#5b21b6;fontColor=#0F172A;fontSize=9;align=center;verticalAlign=bottom;labelPosition=center;verticalLabelPosition=bottom;" vertex="1" parent="tier4">
          <mxGeometry x="60" y="155" width="60" height="60" as="geometry" />
        </mxCell>

        <mxCell id="cw-box" value="Structured JSON logs: function · request ID · user ID · hospital ID · timestamp WAT · level · message (REQ-NF-024)&#xa;Alarms: Lambda error rate &gt;5/min OR RDS CPU &gt;80% for 5 min → SNS → admin within 5 min (REQ-NF-019)&#xa;CloudTrail: all AWS API calls → versioned write-protected S3 bucket · 2yr retention (REQ-F-071)" style="rounded=1;whiteSpace=wrap;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=9;fontColor=#0F172A;align=left;verticalAlign=top;" vertex="1" parent="tier4">
          <mxGeometry x="145" y="148" width="720" height="65" as="geometry" />
        </mxCell>

        <mxCell id="t4-note" value="Two-tier audit: CloudTrail = infrastructure AWS API calls | application_audit_log in RDS = clinical data access (INSERT/SELECT only, REQ-F-068–070). Both required for Cameroon Law No. 2010/012 compliance." style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=9;fontColor=#475569;fontStyle=2;" vertex="1" parent="tier4">
          <mxGeometry x="30" y="242" width="840" height="20" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════ -->
        <!-- LEGEND                     -->
        <!-- ═══════════════════════════ -->
        <mxCell id="legend" value="LEGEND — Connection Types" style="swimlane;startSize=28;fillColor=#f8fafc;strokeColor=#94a3b8;fontStyle=1;fontSize=10;fontColor=#0F172A;rounded=1;arcSize=4;" vertex="1" parent="1">
          <mxGeometry x="30" y="2010" width="900" height="160" as="geometry" />
        </mxCell>

        <mxCell id="leg1" value="━━━  HTTPS / TLS 1.3 — browser to AWS endpoints" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#0D9488;" vertex="1" parent="legend">
          <mxGeometry x="20" y="38" width="420" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg2" value="━━━  Lambda to RDS — TCP port 5432, VPC internal" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#ca8a04;" vertex="1" parent="legend">
          <mxGeometry x="20" y="62" width="420" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg3" value="- - -  Async event / S3 trigger / DLQ" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#ea580c;" vertex="1" parent="legend">
          <mxGeometry x="20" y="86" width="420" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg4" value="━━━  Lambda to SNS/SES — HTTPS port 443 via SG rule" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#c2410c;" vertex="1" parent="legend">
          <mxGeometry x="20" y="110" width="420" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg5" value="━━━  Observability / audit flow" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#7c3aed;" vertex="1" parent="legend">
          <mxGeometry x="460" y="38" width="420" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg6" value="━━━  Encryption — AES-256 AWS managed keys" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#854d0e;" vertex="1" parent="legend">
          <mxGeometry x="460" y="62" width="420" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg7" value="Region: us-east-1 (MVP) → af-south-1 (production)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#0F172A;fontStyle=1;" vertex="1" parent="legend">
          <mxGeometry x="460" y="86" width="420" height="22" as="geometry" />
        </mxCell>
        <mxCell id="leg8" value="All timestamps in WAT (UTC+1) — Cameroon timezone" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontColor=#0F172A;" vertex="1" parent="legend">
          <mxGeometry x="460" y="110" width="420" height="22" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════ -->
        <!-- DATA FLOW ARROWS            -->
        <!-- ═══════════════════════════ -->

        <!-- Browser → Amplify (implied by tier0 placement, arrow from outside) -->
        <mxCell id="e-client-amplify" value="HTTPS / TLS 1.3" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#0D9488;strokeWidth=2;fontColor=#0D9488;fontSize=9;fontStyle=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" edge="1" parent="1" target="amplify">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="160" y="55" as="sourcePoint" />
          </mxGeometry>
        </mxCell>

        <!-- API GW → Lambdas -->
